{
  "name": "examlly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "kill:3000": "lsof -ti:3000 | xargs kill -9",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:status": "supabase status",
    "gen-types:local": "supabase gen types typescript --local > lib/supabase/database.types.ts",
    "gen-types:dev": "supabase gen types typescript --project-id fpbglwvzpmqmtdtrhuhc > lib/supabase/database.types.ts",
    "gen-types:prod": "supabase gen types typescript --project-id nktwfzcadffzfthslckx > lib/supabase/database.types.ts",
    "docs:serve": "npx @arabold/docs-mcp-server@latest --store-path ./docs-mcp/data",
    "docs:export": "cp ./docs-mcp/data/documents.db ./docs-mcp/documents.db && echo 'Exported docs-mcp database to docs-mcp/documents.db'",
    "docs:build": "docker build -t ghcr.io/viveka-labs/bob-the-builder-docs-mcp:latest ./docs-mcp",
    "docs:login": "gh auth token | docker login ghcr.io -u $(gh api user --jq .login) --password-stdin",
    "docs:push": "docker push ghcr.io/viveka-labs/bob-the-builder-docs-mcp:latest",
    "docs:publish": "npm run docs:export && npm run docs:build && npm run docs:push",
    "docs:start": "docker run -d --name bob-the-builder-docs-mcp -p 6280:6280 ghcr.io/viveka-labs/bob-the-builder-docs-mcp:latest --protocol http --host 0.0.0.0 --port 6280 && echo 'Docs MCP server running at http://localhost:6280'",
    "docs:stop": "docker stop bob-the-builder-docs-mcp && docker rm bob-the-builder-docs-mcp",
    "docs:pull": "docker pull ghcr.io/viveka-labs/bob-the-builder-docs-mcp:latest",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "supabase": "^2.76.17",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
