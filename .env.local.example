# Supabase Configuration
# Copy this file to .env.local and fill in your credentials.
#
#   cp .env.local.example .env.local
#
# ─────────────────────────────────────────────────────────
# OPTION A — Frontend-only development (recommended for most)
#   No Docker required. Use the shared production credentials.
#   Ask the team lead for these values on Discord.
#
#   NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
#
# OPTION B — Backend/database development (requires Docker)
#   Run `supabase start` and use the values it prints out.
#
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable key from supabase start output>
# ─────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# (Optional) Server-only secret key — never prefix with NEXT_PUBLIC_
# SUPABASE_SECRET_KEY=your-secret-key

# (Optional) Required only if running `npm run gen-types:prod`
# Find this in your Supabase dashboard under Project Settings > General
# SUPABASE_PROJECT_ID=your-project-ref
