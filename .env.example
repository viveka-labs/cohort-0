# Supabase Configuration
# Copy this file to .env and fill in your credentials.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────
# Three-Environment Model
#
# This project uses three environments:
#
#   1. LOCAL  — Docker-based Supabase (supabase start). Full control,
#               used for backend/database development.
#   2. DEV    — Shared remote Supabase project (fpbglwvzpmqmtdtrhuhc).
#               Connected to the `dev` branch on Vercel.
#               Used for frontend-only development and integration testing.
#   3. PROD   — Production Supabase project (nktwfzcadffzfthslckx).
#               Connected to the `main` branch on Vercel.
#               Only the team lead deploys here.
#
# ─────────────────────────────────────────────────────────
# OPTION A — Frontend-only development (recommended for most)
#   No Docker required. Use the shared DEV credentials below.
#
#   NEXT_PUBLIC_SUPABASE_URL=https://fpbglwvzpmqmtdtrhuhc.supabase.co
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_bi_dGVTEzxvsyMawGIl4lQ_L3eDGbNI
#
# OPTION B — Backend/database development (requires Docker)
#   Run `supabase start` and use the values it prints out.
#
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable key from supabase start output>
# ─────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://fpbglwvzpmqmtdtrhuhc.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_bi_dGVTEzxvsyMawGIl4lQ_L3eDGbNI

# (Optional) Site URL — used to construct OAuth callback URLs.
# If not set, falls back to NEXT_PUBLIC_VERCEL_URL (auto-set by Vercel)
# then to http://localhost:3000.
# Local development: omit this or set to http://localhost:3000
# Dev:  https://bob-the-builder-git-dev-innovativegamers-projects.vercel.app (set automatically by Vercel)
# Prod: https://bob-the-builder-zeta.vercel.app (set automatically by Vercel)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (Optional) Server-only secret key — never prefix with NEXT_PUBLIC_
# SUPABASE_SECRET_KEY=your-secret-key

# ─────────────────────────────────────────────────────────
# Local Supabase OAuth (Option B / backend development only)
#
# Required when running `supabase start` locally to enable Google and GitHub
# sign-in. The client_id and secret come from a shared dev OAuth app —
# ask the team lead or check the shared team vault.
#
# OAuth App callback URLs to register with each provider:
#   GitHub: http://127.0.0.1:54321/auth/v1/callback (use 127.0.0.1 not localhost — GitHub requires an exact callback URL match)
#   Google: http://127.0.0.1:54321/auth/v1/callback
# ─────────────────────────────────────────────────────────
# SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=Ov23li...
# SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=your-github-oauth-secret

# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=GOCSPX-your-google-oauth-secret
